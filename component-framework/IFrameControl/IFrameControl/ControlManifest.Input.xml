<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control
    namespace="SampleNamespace"
    constructor="IFrameControl"
    version="1.2.1"
    display-name-key="IFrameControl_Display_Key"
    description-key="IFrameControl_Desc_Key"
    control-type="standard">

    <!-- URL do iframe (usado no Canvas App como propriedade do controle) -->
    <property
      name="url"
      display-name-key="Url_Display_Key"
      description-key="Url_Desc_Key"
      of-type="SingleLine.Text"
      usage="input"
      required="false" />

    <resources>
      <code path="index.ts" order="1" />
      <css path="css/IFrameControl.css" order="2" />
      <resx path="strings/IFrameControl.1033.resx" version="1.0.0"/>
    </resources>
  </control>
</manifest>